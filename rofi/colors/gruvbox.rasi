* {
    background:     #3c3836FF;   /* bg1 */
    background-alt: #282828FF;   /* bg0 */
    foreground:     #ebdbb2FF;   /* fg1 */
    selected:       #fabd2fFF;   /* bright yellow — matches waybar accent */
    active:         #b8bb26FF;   /* bright green */
    urgent:         #fb4934FF;   /* bright red */
}
